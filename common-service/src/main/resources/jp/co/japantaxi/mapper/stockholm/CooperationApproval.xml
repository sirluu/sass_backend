	<select id="getBankAccountInfoByAccountID" resultMap="bankaccountinfors">
		SELECT
			bank.sfid,
			bm.name as bankname,
			bm.banknamekana,
			bm.bankcode,
			bm.branchname,
			bm.branchcode,
			bm.branchnamekana,
			bank.accountnumber,
			bank.accountname,
			bank.accountnamekana,
			bank.accounttype as accounttype,
			acc.mertermno as mertermno
		FROM
			bankaccountinformationsync bank
			INNER JOIN bankmastersync bm ON bank.accountbank = bm.sfid
			LEFT JOIN  accountsync acc ON bank.account = acc.sfid
		WHERE account=#{accsfid}
	</select>
