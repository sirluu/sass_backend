# Flask
FLASK_ENV=development
FLASK_APP=app.py
PORT=5000
SECRET_KEY=change-me-in-production
AUTO_INIT_DB=true
SEED_DATABASE=true

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///ecommerce.db
# DATABASE_URL=postgresql://user:password@localhost:5432/sass_paint
DB_SCHEMA=systems

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=3600

# Multi-tenant
DEFAULT_TENANT_SLUG=son-phong-thuy
FRONTEND_URL=http://localhost:5173

# Google Gemini AI
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash

# Pinecone Vector DB
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=ecommerce-products

# Embeddings (must match Pinecone index dimensions)
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024

# Production notes:
# - Set AUTO_INIT_DB=false and SEED_DATABASE=false after first deploy
# - Use strong random values for SECRET_KEY and JWT_SECRET_KEY
# - See docs/DEPLOYMENT.md for full deployment guide
